    <!-- 功能 1: 前端配速計算效果 -->
    <div class="card">
        <h2>3. 跑步目標配速換算</h2>
        <div class="form-grid">
            <div class="form-group">
                <label for="distance">訓練距離</label>
                <select id="distance" onchange="checkCustomDistance(); calculatePace();">
                    <option value="5000">5 公里 (5K)</option>
                    <option value="10000">10 公里 (10K)</option>
                    <option value="21097">半程馬拉松 (21.097K)</option>
                    <option value="42195">全程馬拉松 (42.195K)</option>
                    <option value="custom">自訂距離 (公尺)</option>
                </select>
            </div>
            <div class="form-group" id="custom-distance-group" style="display: none;">
                <label for="custom-distance">自訂距離 (公尺)</label>
                <input type="number" id="custom-distance" value="1500" oninput="calculatePace()">
            </div>
        </div>
        
        <div class="form-grid">
            <div class="form-group">
                <label for="time-hr">目標時</label>
                <input type="number" id="time-hr" value="0" min="0" oninput="calculatePace()">
            </div>
            <div class="form-group">
                <label for="time-min">目標分</label>
                <input type="number" id="time-min" value="25" min="0" max="59" oninput="calculatePace()">
            </div>
            <div class="form-group">
                <label for="time-sec">目標秒</label>
                <input type="number" id="time-sec" value="0" min="0" max="59" oninput="calculatePace()">
            </div>
        </div>

        <div class="result-box">
            計算結果配速：<span id="pace-result">5'00"</span> / 公里
        </div>
    </div>

    <!-- 功能 3: 將資料同步至 GAS 存入 Google Sheet -->
    <div class="card">
        <h2>4. 同步資料至雲端資料庫 (Google Sheets)</h2>
        <div class="form-group" style="margin-bottom: 15px;">
            <label for="gas-url">您的 GAS 網頁應用程式 URL</label>
            <input type="text" id="gas-url" placeholder="https://script.google.com/macros/s/.../exec">
            <small style="color: var(--text-muted); font-size: 12px; margin-top: 4px;">
                * 請將佈署好的 GAS Web App 網址貼於此處進行串接測試。
            </small>
        </div>
        
        <button type="button" class="btn" id="btn-submit" onclick="submitDataToGoogleSheet()">
            <span id="submit-loading" style="display:none;" class="loading"></span>
            確認上傳訓練數據
        </button>
        
        <div id="status-message" class="status-msg"></div>
    </div>
</div>

<script>
    // 頁面載入完成後先執行一次心率計算
    window.onload = function() {
        calculateHeartRateZones();
        calculatePace();
    };

    // 功能 2: 呼叫免費 Open-Meteo 天氣 API (不需 API 金鑰，最適合 GitHub Pages 示範)
    async function fetchWeatherData() {
        const apiBtnText = document.getElementById('api-btn-text');
        const apiLoading = document.getElementById('api-loading');
        
        apiBtnText.innerText = "正在定位與取得天氣...";
        apiLoading.style.display = "inline-block";

        // 預設台北經緯度
        let lat = 25.03;
        let lon = 121.56;

        // 嘗試使用瀏覽器原生定位取得精準位置
        if (navigator.geolocation) {
            try {
                const position = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, { timeout: 5000 });
                });
                lat = position.coords.latitude;
                lon = position.coords.longitude;
            } catch (e) {
                console.log("無法取得精準定位，將使用預設城市座標");
            }
        }

        try {
            const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
            const data = await response.json();
            if (data && data.current_weather) {
                document.getElementById('temperature').value = data.current_weather.temperature;
                apiBtnText.innerText = "氣溫資料載入成功！";
                setTimeout(() => { apiBtnText.innerText = "呼叫氣象 API 自動填入當前氣溫"; }, 3000);
            }
        } catch (error) {
            console.error("API 呼叫失敗:", error);
            apiBtnText.innerText = "載入失敗，請手動輸入";
        } finally {
            apiLoading.style.display = "none";
        }
    }

    // 功能 1: 處理自訂距離輸入框顯示
    function checkCustomDistance() {
        const distanceSelect = document.getElementById('distance').value;
        const customGroup = document.getElementById('custom-distance-group');
        if (distanceSelect === 'custom') {
            customGroup.style.display = 'flex';
        } else {
            customGroup.style.display = 'none';
        }
    }

    // 功能 1: 前端動態計算心率區間 (最大心率採用儲備心率 Karvonen 公式法，更專業)
    function calculateHeartRateZones() {
        const age = parseInt(document.getElementById('age').value) || 25;
        const restingHr = parseInt(document.getElementById('resting-hr').value) || 60;
        
        const maxHr = 220 - age;
        const hrReserve = maxHr - restingHr; // 儲備心率

        // 計算各區間範圍並即時渲染到網頁畫面上
        document.getElementById('z1-range').innerText = `${Math.round(restingHr + hrReserve * 0.50)} - ${Math.round(restingHr + hrReserve * 0.60)} bpm`;
        document.getElementById('z2-range').innerText = `${Math.round(restingHr + hrReserve * 0.60)} - ${Math.round(restingHr + hrReserve * 0.70)} bpm`;
        document.getElementById('z3-range').innerText = `${Math.round(restingHr + hrReserve * 0.70)} - ${Math.round(restingHr + hrReserve * 0.80)} bpm`;
        document.getElementById('z4-range').innerText = `${Math.round(restingHr + hrReserve * 0.80)} - ${Math.round(restingHr + hrReserve * 0.90)} bpm`;
        document.getElementById('z5-range').innerText = `${Math.round(restingHr + hrReserve * 0.90)} - ${maxHr} bpm`;
    }

    // 功能 1: 前端動態配速換算效果
    function calculatePace() {
        const distanceSelect = document.getElementById('distance').value;
        let distance = 0;
        
        if (distanceSelect === 'custom') {
            distance = parseFloat(document.getElementById('custom-distance').value) || 0;
        } else {
            distance = parseFloat(distanceSelect);
        }

        const hr = parseInt(document.getElementById('time-hr').value) || 0;
        const min = parseInt(document.getElementById('time-min').value) || 0;
        const sec = parseInt(document.getElementById('time-sec').value) || 0;

        const totalSeconds = (hr * 3600) + (min * 60) + sec;

        if (distance === 0 || totalSeconds === 0) {
            document.getElementById('pace-result').innerText = "--'--"";
            return;
        }

        // 計算每公里的秒數
        const secondsPerKm = totalSeconds / (distance / 1000);
        const paceMin = Math.floor(secondsPerKm / 60);
        const paceSec = Math.round(secondsPerKm % 60);

        // 格式化輸出，補零效果
        const formattedSec = paceSec < 10 ? '0' + paceSec : paceSec;
        document.getElementById('pace-result').innerText = `${paceMin}'${formattedSec}"`;
    }

    // 功能 3: 透過 JavaScript Fetch 送出 POST 請求到 GAS (解決 GitHub CORS 問題)
    async function submitDataToGoogleSheet() {
        const gasUrl = document.getElementById('gas-url').value.trim();
        const statusMsg = document.getElementById('status-message');
        const submitLoading = document.getElementById('submit-loading');
        
        if (!gasUrl) {
            alert('請先輸入您的 GAS 網頁應用程式網址 (Web App URL)！');
            return;
        }

        statusMsg.style.display = "none";
        submitLoading.style.display = "inline-block";

        // 打包準備送出的資料
        const payload = {
            runnerName: document.getElementById('runner-name').value,
            temperature: document.getElementById('temperature').value || "未記錄",
            age: document.getElementById('age').value,
            restingHr: document.getElementById('resting-hr').value,
            pace: document.getElementById('pace-result').innerText,
            timestamp: new Date().toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })
        };

        try {
            // 重點：使用 text/plain 防止瀏覽器發送 OPTIONS 預檢請求，這是靜態網頁對接 GAS 避開 CORS 的標準寫法
            const response = await fetch(gasUrl, {
                method: 'POST',
                mode: 'cors',
                headers: {
                    'Content-Type': 'text/plain;charset=utf-8'
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            
            if (result.status === 'success') {
                statusMsg.className = "status-msg success";
                statusMsg.innerText = "🎉 訓練數據已成功寫入 Google Sheets！";
            } else {
                statusMsg.className = "status-msg error";
                statusMsg.innerText = "❌ 寫入失敗：" + result.message;
            }
        } catch (error) {
            console.error("傳送至 GAS 發生錯誤:", error);
            // 注意：如果 GAS 回傳不是 JSON 標準格式或設定不當，仍可能落入 catch，但在 Sheets 裡其實已經成功寫入
            statusMsg.className = "status-msg success";
            statusMsg.innerText = "系統已發出請求。請檢查您的 Google Sheets 試算表是否已新增資料！";
        } finally {
            statusMsg.style.display = "block";
            submitLoading.style.display = "none";
        }
    }
</script>

</body>
</html>
